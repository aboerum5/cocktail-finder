<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Saved Cocktails</title>
  <link rel="stylesheet" href="/styles.css">
</head>

<body>
  <header>
    <h1>Saved Cocktails</h1>
    <p>Your saved cocktail ideas are listed below.</p>
  </header>

  <main class="container">
    <div class="top-links">
      <a href="/">Search Cocktails</a>
      <% if (savedCocktails && savedCocktails.length > 0) { %>
        <form action="/cocktails/saved/clear" method="POST" style="display:inline;">
          <button type="submit" class="clear-button">Clear All</button>
        </form>
      <% } %>
    </div>

    <% if (savedCocktails && savedCocktails.length > 0) { %>
      <% const uniqueIngredients = [...new Set(savedCocktails.map(c => c.searchedIngredient))]; %>
      <section class="card filter-bar">
        <label for="filter">Filter by ingredient:</label>
        <select id="filter" onchange="filterCocktails(this.value)">
          <option value="all">All</option>
          <% uniqueIngredients.forEach(function(ing) { %>
            <option value="<%= ing %>"><%= ing %></option>
          <% }); %>
        </select>
      </section>
    <% } %>

    <% if (!savedCocktails || savedCocktails.length === 0) { %>
      <section class="card">
        <h2>No saved cocktails yet</h2>
        <p>Search for an ingredient and save cocktails you like.</p>
      </section>
    <% } else { %>
      <section class="results-grid">
        <% savedCocktails.forEach(function(cocktail) { %>
          <div class="cocktail-card" data-ingredient="<%= cocktail.searchedIngredient %>">
            <img 
              src="<%= cocktail.image %>" 
              alt="<%= cocktail.name %>"
            >

            <h2><%= cocktail.name %></h2>

            <p>
              Found from search:
              <strong><%= cocktail.searchedIngredient %></strong>
            </p>
          </div>
        <% }); %>
      </section>
    <% } %>
  </main>
  <script>
    function filterCocktails(ingredient) {
      document.querySelectorAll('.cocktail-card').forEach(function(card) {
        card.style.display = (ingredient === 'all' || card.dataset.ingredient === ingredient) ? '' : 'none';
      });
    }
  </script>
</body>
</html>